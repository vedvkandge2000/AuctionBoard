# ══════════════════════════════════════════════════════════════
#  AuctionBoard — unified environment file
#  Place this file as .env at the repo root.
#  Server reads it via an explicit dotenv path (server/index.js).
#  Client (Vite) reads it via envDir set to repo root (vite.config.js).
#  Only variables prefixed with VITE_ are exposed to the browser.
# ══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=8000
MONGO_URI=mongodb://localhost:27017/auctionboard
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Public IP or domain of your server (used for CORS and reset-password links)
# Example for EC2: http://54.227.40.172
# Example for domain: https://auctionboard.io
CLIENT_URL=http://localhost:5173

# Image storage: 'local' (default, stores in server/uploads/) or 'cloudinary'
STORAGE_BACKEND=local

# ── Cloudinary (set STORAGE_BACKEND=cloudinary to activate) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email / SMTP (required for forgot-password flow) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=no-reply@auctionboard.io

# ── App config ────────────────────────────────────────────────
CONTACT_EMAIL=admin@auctionboard.io

# ── Client (exposed to browser via Vite — must be VITE_ prefixed) ──
# API base URL — in production set to your server's public URL
# In development this is unused (Vite proxy handles /api → localhost:8000)
VITE_API_URL=http://localhost:8000

# Contact email shown on the landing page and About page
VITE_CONTACT_EMAIL=admin@auctionboard.io
