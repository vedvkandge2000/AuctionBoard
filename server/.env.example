NODE_ENV=production
PORT=8000
MONGO_URI=mongodb://localhost:27017/auctionboard
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:8000

# Image storage: 'local' (default, stores in server/uploads/) or 'cloudinary'
STORAGE_BACKEND=local

# ── Cloudinary (set STORAGE_BACKEND=cloudinary to activate) ──────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
